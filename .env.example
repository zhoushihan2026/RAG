# OpenAI API 配置
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_BASE_URL=https://api.openai.com/v1

# fe8.cn API 配置（用于调用 GPT 系列模型）
FE8_API_KEY=sk-your-fe8-api-key

# DashScope API 配置（通义千问 / Embedding / Rerank）
DASHSCOPE_API_KEY=your-dashscope-api-key

# MinerU PDF 解析 API 配置
MINERU_API_KEY=your-mineru-api-key

# IBM API 配置
IBM_API_KEY=your-ibm-api-key

# Gemini API 配置
GEMINI_API_KEY=your-gemini-api-key

# Jina API 配置（可选，用于 Rerank）
JINA_API_KEY=your-jina-api-key

# CORS 允许的前端来源（逗号分隔，留空则使用开发默认值）
# CORS_ORIGINS=http://localhost:5173,http://localhost:5174

# 数据存储路径（默认 data/stock_data）
# RAG_DATA_PATH=data/stock_data
